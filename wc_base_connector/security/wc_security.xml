<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_wc" model="ir.module.category">
            <field name="name">WooCommerce</field>
            <field name="sequence">25</field>
        </record>
        <record id="group_wc_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_wc"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_wc_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_wc"/>
            <field name="implied_ids" eval="[(4, ref('group_wc_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
